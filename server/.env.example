# ── Data source ──────────────────────────────────────────────────────────────
# auto (default) | mock | henrik | riot
#   auto  → henrik if HENRIK_API_KEY is set, else riot if RIOT_API_KEY is set,
#           else mock (deterministic demo data, no keys needed)
DATA_SOURCE=auto

# Official Riot API key (https://developer.riotgames.com — dev keys expire every 24h)
# RIOT_API_KEY=RGAPI-xxxx-xxxx-xxxx

# HenrikDev API key (free — request in their Discord: https://docs.henrikdev.xyz)
# HENRIK_API_KEY=HDEV-xxxx-xxxx-xxxx

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
# Comma-separated origins, or * (default) for development
CORS_ORIGIN=*
